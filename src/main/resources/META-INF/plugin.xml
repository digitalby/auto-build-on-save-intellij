<idea-plugin>
    <id>info.yuryv.auto-build-on-save</id>
    <name>Auto Build on Save</name>
    <vendor email="jbsupport@yuryv.info" url="https://yuryv.info">Yury Vashchylau</vendor>
    <version>1.0.0</version>

    <description><![CDATA[
        <p>Automatically triggers an incremental build whenever you save a file in the project.
        Skips the build if the IDE reports linter errors. Configure via
        <b>Settings / Preferences &gt; Tools &gt; Auto Build on Save</b>.</p>
        <ul>
            <li>Incremental build on every file save</li>
            <li>Optional error guard (skip build when linter errors exist)</li>
            <li>Configurable debounce delay (default 1500 ms)</li>
        </ul>
    ]]></description>

    <change-notes><![CDATA[
        <b>1.0.0</b> - Initial version
    ]]></change-notes>

    <!-- Works with IntelliJ-based IDEs including Android Studio -->
    <idea-version since-build="241" until-build="251.*"/>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Notification group for build-skipped warnings -->
        <notificationGroup id="Auto Build on Save"
                           displayType="BALLOON"
                           toolWindowId="Problems"/>
        <!-- Settings page under Tools > Auto Build on Save -->
        <applicationConfigurable
                parentId="tools"
                instance="info.yuryv.AutoBuildSettingsConfigurable"
                id="info.yuryv.autobuildsettingsconfigurable"
                displayName="Auto Build on Save"/>

        <!-- Persistent settings storage -->
        <applicationService
                serviceImplementation="info.yuryv.AutoBuildSettings"/>
    </extensions>

    <applicationListeners>
        <!-- Listen for file saves -->
        <listener
                class="info.yuryv.AutoBuildOnSaveListener"
                topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"/>
    </applicationListeners>
</idea-plugin>
